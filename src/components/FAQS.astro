---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { heading, faqs } = Astro.props.data.content.faqsSection;
---

{
	faqs && Array.isArray(faqs) && faqs.length > 0 && (
		<section id="faqs" class="scrolling-section section-shell">
			<div class="container-shell">
				<div class="section-heading-center">
					<p class="section-kicker">FAQs</p>
					<h2 class="section-title" style="max-width: 10ch;">
						{heading}
					</h2>
					<p class="section-copy">
						Quick answers to common questions about installation, monitoring, and support.
					</p>
				</div>

				<div class="mx-auto mt-16 grid max-w-5xl gap-4">
					{faqs.map((faq) => (
						<details class="faq-item group transition duration-300 hover:-translate-y-0.5">
							<summary class="cursor-pointer list-none">
								<div class="flex items-start justify-between gap-6">
									<p class="text-base font-semibold leading-7 text-[var(--color-heading)]">
										{faq.question}
									</p>
									<span class="faq-toggle" aria-hidden="true">
										<Icon name="heroicons-solid:chevron-down" class="h-5 w-5" style="color: var(--color-heading);" />
									</span>
								</div>
							</summary>
							<div class="mt-4 text-sm leading-7 text-[var(--color-text-muted)]">
								{faq.answer}
							</div>
						</details>
					))}
				</div>
			</div>
		</section>
	)
}

<style>
	details > summary::-webkit-details-marker {
		display: none;
	}
</style>

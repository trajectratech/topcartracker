---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { heading, faqs } = Astro.props.data.content.faqsSection;
---

{
	faqs && Array.isArray(faqs) && faqs.length > 0 && (
		<section id="faqs" class="scrolling-section bg-[var(--color-background)] px-6 py-28">
			<div class="mx-auto max-w-7xl">
				<div class="mx-auto max-w-3xl text-center">
					<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
						FAQs
					</p>
					<h2 class="mt-6 text-4xl font-black tracking-tight sm:text-5xl" style="color: var(--color-heading);">
						{heading}
					</h2>
					<p class="mt-6 text-lg leading-8" style="color: var(--color-text);">
						Quick answers to common questions about installation, monitoring, and support.
					</p>
				</div>

				<div class="mx-auto mt-16 grid max-w-5xl gap-4">
					{faqs.map((faq) => (
						<details
							class="card group rounded-[28px] p-6 transition duration-300 hover:-translate-y-0.5"
							style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
						>
							<summary class="cursor-pointer list-none">
								<div class="flex items-start justify-between gap-6">
									<p class="text-base font-semibold leading-7" style="color: var(--color-heading);">
										{faq.question}
									</p>
									<span
										class="flex h-10 w-10 items-center justify-center rounded-full transition duration-300 group-open:rotate-180"
										style="background: color-mix(in srgb, var(--color-muted) 70%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
										aria-hidden="true"
									>
										<Icon name="heroicons-solid:chevron-down" class="h-5 w-5" style="color: var(--color-heading);" />
									</span>
								</div>
							</summary>
							<div class="mt-4 text-sm leading-7" style="color: var(--color-text);">
								{faq.answer}
							</div>
						</details>
					))}
				</div>
			</div>
		</section>
	)
}

<style>
	details > summary::-webkit-details-marker {
		display: none;
	}
</style>

---
import type { ThemeConfig } from "../types/theme";
import CallToActionButton from "./CallToActionButton.astro";
import LottiePlayer from "./tsx/lottie-player";
import { formatPhoneDisplay } from "../utils/formatPhone";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const content = data.content.aboutSection;
const contact = data.contact;
const displayPhone = formatPhoneDisplay(contact.phone);

const hasAboutContent =
	content?.heading?.trim() ||
	content?.paragraph?.trim() ||
	content?.imageUrl?.trim();

const hasLottie = content.hasLottie;
const lottie = content.lottiePath;
---

{
	hasAboutContent && (
		<section
			id="about"
			aria-labelledby="about-heading"
			class="scrolling-section section-shell relative isolate text-[var(--color-text)]"
			data-surface="muted"
		>
			<div class="container-shell grid items-start gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:gap-16">
				<div class="text-left">
					<p class="section-kicker">About</p>
					<h2 id="about-heading" class="section-title" style="max-width: 12ch;">
						{content.heading}
					</h2>
					<p class="section-copy">
						{content.paragraph}
					</p>

					<div class="mt-8 grid gap-3">
						<p class="list-check">Trusted installation guidance from first enquiry to activation.</p>
						<p class="list-check">Security-focused recommendations based on the vehicle and use case.</p>
						<p class="list-check">Support that remains useful after installation, not only before payment.</p>
					</div>

					<address class="mt-10 not-italic grid items-start gap-4 sm:grid-cols-2">
						{contact.email && (
							<a
								href={`mailto:${contact.email}`}
								data-button
								class="step-card cursor-pointer transition duration-300 hover:-translate-y-0.5"
								aria-label={`Send an email to ${contact.email}`}
							>
								<p class="eyebrow-label">
									Email
								</p>
								<p class="mt-4 text-base font-semibold text-[var(--color-heading)]">
									{contact.email}
								</p>
							</a>
						)}

						{contact.phone && (
							<a
								href={`tel:${contact.phone}`}
								data-button
								class="step-card cursor-pointer transition duration-300 hover:-translate-y-0.5"
								aria-label={`Call ${contact.phone}`}
							>
								<p class="eyebrow-label">
									Phone
								</p>
								<p class="mt-4 text-base font-semibold text-[var(--color-heading)]">
									{displayPhone}
								</p>
							</a>
						)}
					</address>

					{data?.content?.heroSection?.ctaUrl && (
						<CallToActionButton
							href={data.content.heroSection.ctaUrl}
							label={data.content.heroSection.ctaText}
							className="mt-10"
						/>
					)}
				</div>

				<div class="premium-panel p-6">
					<div class="soft-card p-6">
						{content.imageUrl && (
							<div class="overflow-hidden rounded-[1.75rem]" style="border: 1px solid var(--border-subtle);">
								<div class="relative w-full" style="aspect-ratio: 16 / 11;">
									<img
										src={content.imageUrl}
										alt=""
										aria-hidden="true"
										class="absolute inset-0 h-full w-full object-cover transition duration-500 hover:scale-105"
										loading="lazy"
										decoding="async"
										fetchpriority="low"
									/>
								</div>
							</div>
						)}

						{!content?.imageUrl && hasLottie && lottie && (
							<div class="js-only h-[360px] w-full overflow-hidden rounded-[1.75rem]" style="border: 1px solid var(--border-subtle);">
								<LottiePlayer client:visible path={lottie} />
							</div>
						)}

						<div class="mt-6 grid items-start gap-4 sm:grid-cols-2">
							<div class="step-card">
								<p class="eyebrow-label">
									Address
								</p>
								<p class="mt-4 text-sm font-semibold leading-7 text-[var(--color-heading)]">
									{contact.address}
								</p>
							</div>
							<div class="step-card">
								<p class="eyebrow-label">
									Support
								</p>
								<p class="mt-4 text-sm font-semibold leading-7 text-[var(--color-heading)]">
									Advice before and after installation
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}

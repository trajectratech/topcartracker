---
import type { ThemeConfig } from "../types/theme";
import CallToActionButton from "./CallToActionButton.astro";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const content = data.content.aboutSection;
const contact = data.contact;

const hasAboutContent =
	content?.heading?.trim() ||
	content?.paragraph?.trim() ||
	content?.imageUrl?.trim();

const hasLottie = content.hasLottie;
const lottie = content.lottiePath;
---

{
	hasAboutContent && (
		<section
			id="about"
			aria-labelledby="about-heading"
			class="scrolling-section relative isolate bg-[var(--color-background)] px-6 py-28 text-[var(--color-text)]"
		>
			<div class="absolute inset-0 -z-10 opacity-60" aria-hidden="true"
				style="background: radial-gradient(circle at bottom right, color-mix(in srgb, var(--color-accent) 14%, transparent) 0%, transparent 60%);"
			></div>

			<div class="mx-auto grid max-w-7xl items-start gap-14 lg:grid-cols-[0.95fr_1.05fr]">
				<div class="text-left">
					<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
						About
					</p>
					<h2 id="about-heading" class="mt-6 text-4xl font-black tracking-tight sm:text-5xl" style="color: var(--color-heading);">
						{content.heading}
					</h2>
					<p class="mt-6 text-lg leading-8" style="color: var(--color-text);">
						{content.paragraph}
					</p>

					<address class="mt-10 not-italic grid items-start gap-4 sm:grid-cols-2">
						{contact.email && (
							<a
								href={`mailto:${contact.email}`}
								data-button
								class="cursor-pointer rounded-[24px] p-6 transition duration-300 hover:-translate-y-0.5"
								style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
								aria-label={`Send an email to ${contact.email}`}
							>
								<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
									Email
								</p>
								<p class="mt-4 text-base font-semibold" style="color: var(--color-heading);">
									{contact.email}
								</p>
							</a>
						)}

						{contact.phone && (
							<a
								href={`tel:${contact.phone}`}
								data-button
								class="cursor-pointer rounded-[24px] p-6 transition duration-300 hover:-translate-y-0.5"
								style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
								aria-label={`Call ${contact.phone}`}
							>
								<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
									Phone
								</p>
								<p class="mt-4 text-base font-semibold" style="color: var(--color-heading);">
									{contact.phone}
								</p>
							</a>
						)}
					</address>

					{data?.content?.heroSection?.ctaUrl && (
						<CallToActionButton
							href={data.content.heroSection.ctaUrl}
							label={data.content.heroSection.ctaText}
						/>
					)}
				</div>

				<div
					class="rounded-[34px] p-6"
					style="background: color-mix(in srgb, var(--color-muted) 70%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
				>
					<div
						class="rounded-[32px] p-6"
						style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
					>
						{content.imageUrl && (
							<div class="overflow-hidden rounded-[28px]" style="border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);">
								<div class="relative w-full" style="aspect-ratio: 16 / 11;">
									<img
										src={content.imageUrl}
										alt=""
										aria-hidden="true"
										class="absolute inset-0 h-full w-full object-cover transition duration-500 hover:scale-105"
										loading="lazy"
										decoding="async"
										fetchpriority="low"
									/>
								</div>
							</div>
						)}

						{!content?.imageUrl && hasLottie && lottie && (
							<div class="js-only h-[360px] w-full overflow-hidden rounded-[28px]" style="border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);">
								<lottie-player
									src={lottie}
									background="transparent"
									speed="1"
									loop
									autoplay
									style="width: 100%; height: 100%"
								/>
							</div>
						)}

						<div class="mt-6 grid items-start gap-4 sm:grid-cols-2">
							<div
								class="rounded-[24px] p-6"
								style="background: color-mix(in srgb, var(--color-muted) 62%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
							>
								<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
									Address
								</p>
								<p class="mt-4 text-sm font-semibold leading-7" style="color: var(--color-heading);">
									{contact.address}
								</p>
							</div>
							<div
								class="rounded-[24px] p-6"
								style="background: color-mix(in srgb, var(--color-muted) 62%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
							>
								<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
									Support
								</p>
								<p class="mt-4 text-sm font-semibold leading-7" style="color: var(--color-heading);">
									Advice before and after installation
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}

---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";
export interface Props {
	data: ThemeConfig;
}
const cta = Astro.props.data.content.ctaSection;
---

{
	cta && (
		<section class="scrolling-section section-shell text-[var(--color-text)]">
			<div class="container-shell">
				<div class="cta-shell p-10 sm:p-14">
					<div class="grid items-start gap-12 lg:grid-cols-[1.08fr_0.92fr]">
					<div>
						<p class="section-kicker">Get Started</p>
						<h2 class="mt-7 max-w-4xl text-[clamp(2.7rem,4.5vw,4.6rem)] font-black leading-[0.95] tracking-[-0.06em] text-[var(--color-heading)]">
							{cta.heading}
						</h2>
						{cta.subheading && (
							<p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--color-text-muted)]">
								{cta.subheading}
							</p>
						)}
						<a
							href={cta.ctaUrl}
							target="_blank"
							rel="noopener noreferrer"
							data-button
							class="primary-button mt-10 inline-flex cursor-pointer items-center justify-center gap-2"
						>
							{cta.ctaText}
							<Icon name="heroicons-solid:external-link" class="h-4 w-4" aria-hidden="true" />
						</a>
					</div>

					<div class="grid items-start gap-4 sm:grid-cols-2">
						<div class="step-card self-start">
							<p class="eyebrow-label">
								Install
							</p>
							<p class="mt-4 text-base font-semibold leading-7 text-[var(--color-heading)]">
								Professional installation at your location
							</p>
						</div>
						<div class="step-card self-start">
							<p class="eyebrow-label">
								Monitor
							</p>
							<p class="mt-4 text-base font-semibold leading-7 text-[var(--color-heading)]">
								Track, alert, and control from your phone
							</p>
						</div>
						<div class="step-card self-start sm:col-span-2">
							<p class="eyebrow-label">
								Support
							</p>
							<p class="mt-4 text-base font-semibold leading-7 text-[var(--color-heading)]">
								Advice before and after installation, with responsive after-sales support
							</p>
						</div>
					</div>
					</div>
				</div>
			</div>
		</section>
	)
}

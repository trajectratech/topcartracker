---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

import CallToActionButton from "./CallToActionButton.astro";

export interface Props {
	data: ThemeConfig;
}

const howItWorksSection = Astro.props.data.content.howItWorksSection;
const steps =
	howItWorksSection?.steps && howItWorksSection.steps.length > 0
		? howItWorksSection.steps
		: [
				{
					title: "Get a recommendation",
					description: "Tell us your vehicle type and what you want to monitor. We recommend the right setup.",
				},
				{
					title: "Book installation",
					description: "We arrange installation at your location or a preferred service point based on coverage.",
				},
				{
					title: "Start monitoring",
					description: "Track your vehicle, set alerts, and monitor activity from your phone or web dashboard.",
				},
			];
const shouldRenderSection = Boolean(
	howItWorksSection &&
		(steps.length > 0 || howItWorksSection.url),
);
---

{
	(
		shouldRenderSection && (
			<section class="scrolling-section bg-[var(--color-background)] px-6 py-28 text-[var(--color-text)]">
				<div class="mx-auto max-w-7xl">
					<div class="mx-auto max-w-3xl text-center">
						<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
							Process
						</p>
						{howItWorksSection?.heading && (
							<h2 class="mt-6 text-4xl font-black tracking-tight sm:text-5xl" style="color: var(--color-heading);">
								{howItWorksSection.heading}
							</h2>
						)}
						<p class="mt-6 text-lg leading-8" style="color: var(--color-text);">
							A clean, premium setup from your first message to active monitoring.
						</p>
					</div>

					<div class="mt-16 grid items-start gap-6 lg:grid-cols-12">
						<div class="lg:col-span-7 grid items-start gap-6 md:grid-cols-3">
							{steps.slice(0, 3).map((step, index) => (
								<div
									class="card self-start rounded-[28px] p-7"
									style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
								>
									<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
										Step {index + 1}
									</p>
									<h3 class="mt-5 text-xl font-bold tracking-tight" style="color: var(--color-heading);">
										{step.title}
									</h3>
									<p class="mt-3 text-sm leading-7" style="color: var(--color-text);">
										{step.description}
									</p>
								</div>
							))}
						</div>

						<div
							class="lg:col-span-5 card self-start rounded-[34px] p-10"
							style="background: color-mix(in srgb, var(--color-muted) 70%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
						>
							<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
								See it in action
							</p>
							<p class="mt-6 text-2xl font-extrabold tracking-tight" style="color: var(--color-heading);">
								Watch how tracking, alerts, and installation works.
							</p>
							<p class="mt-6 text-sm leading-7" style="color: var(--color-text);">
								Understand what you’ll get before you book. Clear steps, clear expectations.
							</p>
							{howItWorksSection?.url && howItWorksSection?.urlText && (
								<div title={howItWorksSection?.urlText}>
									<CallToActionButton
										href={howItWorksSection?.url}
										label={howItWorksSection?.urlText}
									/>
								</div>
							)}
							<div class="mt-10 grid gap-4">
								<div class="flex items-center gap-3">
									<Icon name="heroicons-solid:shield-check" class="h-5 w-5" style="color: var(--color-accent);" aria-hidden="true" />
									<p class="text-sm font-semibold" style="color: var(--color-heading);">
										Professional installation and support
									</p>
								</div>
								<div class="flex items-center gap-3">
									<Icon name="heroicons-solid:clock" class="h-5 w-5" style="color: var(--color-accent);" aria-hidden="true" />
									<p class="text-sm font-semibold" style="color: var(--color-heading);">
										Fast setup and onboarding
									</p>
								</div>
								<div class="flex items-center gap-3">
									<Icon name="heroicons-solid:device-mobile" class="h-5 w-5" style="color: var(--color-accent);" aria-hidden="true" />
									<p class="text-sm font-semibold" style="color: var(--color-heading);">
										Mobile and web monitoring
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
		)
	)
}

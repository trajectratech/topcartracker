---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

import CallToActionButton from "./CallToActionButton.astro";

export interface Props {
	data: ThemeConfig;
}

const howItWorksSection = Astro.props.data.content.howItWorksSection;
const steps =
	howItWorksSection?.steps && howItWorksSection.steps.length > 0
		? howItWorksSection.steps
		: [
				{
					title: "Get a recommendation",
					description: "Tell us your vehicle type and what you want to monitor. We recommend the right setup.",
				},
				{
					title: "Book installation",
					description: "We arrange installation at your location or a preferred service point based on coverage.",
				},
				{
					title: "Start monitoring",
					description: "Track your vehicle, set alerts, and monitor activity from your phone or web dashboard.",
				},
			];
const shouldRenderSection = Boolean(
	howItWorksSection &&
		(steps.length > 0 || howItWorksSection.url),
);
---

{
	(
		shouldRenderSection && (
			<section class="scrolling-section section-shell text-[var(--color-text)]">
				<div class="container-shell">
					<div class="section-heading-center">
						<p class="section-kicker">Process</p>
						{howItWorksSection?.heading && (
							<h2 class="section-title" style="max-width: 14ch;">
								{howItWorksSection.heading}
							</h2>
						)}
						<p class="section-copy">
							A clean, premium setup from your first message to active monitoring.
						</p>
					</div>

					<div class="mt-16 grid items-start gap-8 lg:grid-cols-[1.04fr_0.96fr]">
						<div class="grid items-start gap-4">
							{steps.slice(0, 3).map((step, index) => (
								<div class="step-card">
									<p class="eyebrow-label">
										Step {index + 1}
									</p>
									<h3 class="mt-4 text-xl font-bold tracking-[-0.03em] text-[var(--color-heading)]">
										{step.title}
									</h3>
									<p class="mt-3 text-sm leading-7 text-[var(--color-text-muted)]">
										{step.description}
									</p>
								</div>
							))}
						</div>

						<div class="premium-panel self-start p-10">
							<p class="eyebrow-label">
								See it in action
							</p>
							<p class="mt-5 text-3xl font-black tracking-[-0.05em] text-[var(--color-heading)]">
								Watch how tracking, alerts, and installation works.
							</p>
							<p class="mt-5 text-sm leading-7 text-[var(--color-text-muted)]">
								Understand what you’ll get before you book. Clear steps, clear expectations.
							</p>
							{howItWorksSection?.url && howItWorksSection?.urlText && (
								<div title={howItWorksSection?.urlText}>
									<CallToActionButton
										href={howItWorksSection?.url}
										label={howItWorksSection?.urlText}
										className="mt-10"
									/>
								</div>
							)}
							<div class="mt-10 grid gap-4">
								<div class="step-card flex items-center gap-3 p-5">
									<Icon name="heroicons-solid:shield-check" class="h-5 w-5" style="color: var(--color-primary);" aria-hidden="true" />
									<p class="text-sm font-semibold text-[var(--color-heading)]">
										Professional installation and support
									</p>
								</div>
								<div class="step-card flex items-center gap-3 p-5">
									<Icon name="heroicons-solid:clock" class="h-5 w-5" style="color: var(--color-primary);" aria-hidden="true" />
									<p class="text-sm font-semibold text-[var(--color-heading)]">
										Fast setup and onboarding
									</p>
								</div>
								<div class="step-card flex items-center gap-3 p-5">
									<Icon name="heroicons-solid:device-mobile" class="h-5 w-5" style="color: var(--color-primary);" aria-hidden="true" />
									<p class="text-sm font-semibold text-[var(--color-heading)]">
										Mobile and web monitoring
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
		)
	)
}

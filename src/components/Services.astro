---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { servicesSection } = Astro.props.data.content;
const services = servicesSection?.listItems ?? [];
---

{Array.isArray(servicesSection?.listItems) && servicesSection?.listItems?.length > 0 && <section
	id="services"
	aria-labelledby="services-heading"
	class="scrolling-section section-shell text-[var(--color-text)]"
	data-surface="muted"
>
	<div class="container-shell">
		<div class="section-heading-center">
			<p class="section-kicker">What We Install</p>
			<h2 id="services-heading" class="section-title" style="max-width: 14ch;">
				{servicesSection.heading}
			</h2>
			{servicesSection.paragraph && (
				<p class="section-copy">
					{servicesSection.paragraph}
				</p>
			)}
		</div>

		<div class="mt-16 grid gap-8 lg:grid-cols-[0.86fr_1.14fr]">
			<div class="lg:sticky lg:top-28">
				<div class="premium-panel p-8 sm:p-10">
					<p class="eyebrow-label">Protection stack</p>
					<p class="mt-4 text-3xl font-black tracking-[-0.05em] text-[var(--color-heading)] sm:text-4xl">
						Smart layers that make theft response easier and monitoring clearer.
					</p>
					<p class="mt-5 text-base leading-8 text-[var(--color-text-muted)]">
						Every installation is matched to the vehicle, the risk profile, and the level of monitoring you want afterwards.
					</p>

					<div class="mt-8 grid gap-4">
						{services.slice(0, 3).map((service, index) => (
							<article class="step-card flex items-start gap-4" aria-label={service.title}>
								<div
									class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full"
									style="background: color-mix(in srgb, var(--color-primary) 12%, transparent); color: var(--color-primary);"
								>
									0{index + 1}
								</div>
								<div>
									<p class="text-xl font-bold tracking-[-0.03em] text-[var(--color-heading)]">
										{service.title}
									</p>
									{service.description && (
										<p class="mt-2 text-sm leading-7 text-[var(--color-text-muted)]">
											{service.description}
										</p>
									)}
								</div>
							</article>
						))}
					</div>
				</div>
			</div>

			<div class="grid gap-4">
				<div class="dark-panel p-8 sm:p-9">
					<p class="eyebrow-label" style="color: color-mix(in srgb, var(--color-background) 66%, transparent);">
						Why it converts
					</p>
					<p class="mt-4 text-3xl font-black tracking-[-0.05em]">
						Clients buy confidence, not just hardware.
					</p>
					<div class="mt-6 grid gap-4 text-sm" style="color: color-mix(in srgb, var(--color-background) 78%, transparent);">
						<p class="list-check !text-inherit before:!bg-[var(--color-accent)]">Concealed installation with reliable signal placement.</p>
						<p class="list-check !text-inherit before:!bg-[var(--color-accent)]">Tools selected for real alerts and real recovery response.</p>
						<p class="list-check !text-inherit before:!bg-[var(--color-accent)]">Useful support after installation, not silence after payment.</p>
					</div>
				</div>

				<div class="grid gap-4 sm:grid-cols-2">
					{services.slice(3).map((service, index) => {
						const serviceId = `service-title-${index + 3}`;
						return (
							<article
								aria-label={service.title}
								class={`step-card ${index === 0 ? "sm:col-span-2" : ""}`}
							>
								<div class="flex items-start justify-between gap-4">
									<div>
										<p class="eyebrow-label">Additional layer</p>
										<p id={serviceId} class="mt-3 text-lg font-bold tracking-[-0.03em] text-[var(--color-heading)]">
											{service.title}
										</p>
									</div>
									<div
										class="flex h-11 w-11 items-center justify-center rounded-full"
										style="background: color-mix(in srgb, var(--color-primary) 10%, transparent);"
										aria-hidden="true"
									>
										<Icon name="heroicons-solid:shield-check" class="h-5 w-5 text-[var(--color-primary)]" />
									</div>
								</div>
								{service.description && (
									<p class="mt-4 text-sm leading-7 text-[var(--color-text-muted)]">
										{service.description}
									</p>
								)}
							</article>
						);
					})}
				</div>
			</div>
		</div>
	</div>
</section>
}

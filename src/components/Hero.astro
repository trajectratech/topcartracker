---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";
import CallToActionButton from "./CallToActionButton.astro";
import LottiePlayer from "./tsx/lottie-player";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const content = data.content.heroSection;
const heroImage = data.imagery.heroImage;
const heroImageTextColor = data.imagery.heroTextColor;
const hasHeroImage = !!heroImage;
const heroHasLottie = data.imagery.heroHasLottie;
const heroLottie = data?.imagery?.lottiePath;
const showHeroLottie = Boolean(heroHasLottie && heroLottie);
const trust = data.content?.trustSection;
const highlights = [
	...(trust?.stats?.slice(0, 2).map((stat) => `${stat.value} ${stat.label}`) ?? []),
	...(trust?.guarantees?.slice(0, 1) ?? []),
].filter(Boolean);
// const locationLabel = [data.contact?.addressLocality, data.contact?.addressRegion]
// 	.filter(Boolean)
// 	.join(", ");

const textColor =
	hasHeroImage && heroImageTextColor
		? heroImageTextColor
		: `var(--color-heading)`;
---

{
	content && (
		<section
			class="hero scrolling-section section-shell isolate overflow-hidden pt-8 sm:pt-10"
			aria-labelledby="hero-heading"
		>
			<div class="absolute inset-0 -z-10" aria-hidden="true">
				<div class="absolute left-[-8rem] top-[-10rem] h-[24rem] w-[24rem] rounded-full opacity-60 blur-3xl"
					style="background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 22%, transparent) 0%, transparent 72%);"
				></div>
				<div class="absolute bottom-[-12rem] right-[-6rem] h-[26rem] w-[26rem] rounded-full opacity-45 blur-3xl"
					style="background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 18%, transparent) 0%, transparent 72%);"
				></div>
			</div>

			<div class="container-shell grid items-start gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:gap-16">
				<div class="text-left">
					<p class="section-kicker">GPS Tracking • Vehicle Security</p>

					<h1
						id="hero-heading"
						class="mt-8 max-w-5xl text-[clamp(3.2rem,7vw,6.15rem)] font-black leading-[0.88] tracking-[-0.075em]"
						style={`color: ${textColor}`}
					>
						{content.heading}
					</h1>

					<p class="section-copy max-w-2xl">
						{content.paragraph}
					</p>

					<div class="hero-actions mt-10">
						<CallToActionButton href={content.ctaUrl} label={content.ctaText} />
						<a
							href="#services"
							data-button
							class="secondary-button mt-0 cursor-pointer"
						>
							See protection options
							<Icon name="heroicons-solid:arrow-right" class="h-4 w-4" aria-hidden="true" />
						</a>
					</div>

					<div class="mt-8 grid max-w-3xl gap-3 sm:grid-cols-3">
						{(highlights.length > 0 ? highlights.slice(0, 3) : [
							"Real-time movement alerts",
							"Remote response options",
							"Professional concealed installation",
						]).map((item) => (
							<div class="chip justify-start px-4 py-3 text-sm">
								<Icon name="heroicons-solid:check-circle" class="h-4 w-4 text-[var(--color-primary)]" aria-hidden="true" />
								<span>{item}</span>
							</div>
						))}
					</div>

					<div class="mt-10 grid max-w-2xl gap-4 sm:grid-cols-2">
						{(trust?.stats ?? []).slice(0, 2).map((stat) => (
							<div class="metric-card">
								<p class="eyebrow-label">{stat.label}</p>
								<p class="metric-value">{stat.value}</p>
								<p class="metric-label">
									Built for visibility, response, and dependable after-sales support.
								</p>
							</div>
						))}
					</div>

					<p class="mt-8 inline-note max-w-2xl">
						For private vehicles, executive cars, family cars, and fleets that need clear visibility without complicated setup.
					</p>
				</div>

				<div class="app-frame overflow-hidden">
					<div class="app-toolbar">
						<div class="app-dots" aria-hidden="true">
							<span></span>
							<span></span>
							<span></span>
						</div>
						<div
							class="rounded-full px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.18em]"
							style="background: color-mix(in srgb, white 8%, transparent); color: color-mix(in srgb, var(--color-background) 72%, transparent);"
						>
							Live App View
						</div>
					</div>

					{showHeroLottie && (
						<div
							class="js-only px-5 pt-5"
						>
							<div
								class="overflow-hidden rounded-[1.7rem]"
								style="border: 1px solid color-mix(in srgb, white 8%, transparent); background: linear-gradient(180deg, color-mix(in srgb, white 7%, transparent) 0%, color-mix(in srgb, white 3%, transparent) 100%);"
							>
								<div class="h-[320px] w-full">
									<LottiePlayer client:visible path={heroLottie!} />
								</div>
							</div>
						</div>
					)}

					{!showHeroLottie && hasHeroImage && (
						<div class="px-5 pt-5">
							<div class="overflow-hidden rounded-[1.7rem]" style="border: 1px solid color-mix(in srgb, white 8%, transparent);">
								<img
									src={heroImage}
									alt=""
									aria-hidden="true"
									class="h-[320px] w-full object-cover"
									fetchpriority="high"
									loading="eager"
									decoding="async"
								/>
							</div>
						</div>
					)}

					<div class="grid gap-4 p-5 pt-4">
						<div
							class="rounded-[1.6rem] p-5"
							style="background: color-mix(in srgb, white 6%, transparent); border: 1px solid color-mix(in srgb, white 10%, transparent);"
						>
							<p class="eyebrow-label" style="color: color-mix(in srgb, var(--color-background) 68%, transparent);">
								Vehicle status
							</p>
							<p class="mt-3 text-2xl font-bold tracking-[-0.04em]">
								Car secured and reporting live
							</p>
							<p class="mt-4 text-sm leading-7" style="color: color-mix(in srgb, var(--color-background) 78%, transparent);">
								Location, ignition, and movement data stay visible in one clean interface.
							</p>
						</div>

						<div class="grid gap-3 sm:grid-cols-3">
							{["24/7 visibility", "Smart alerting", "Remote response"].map((item) => (
								<div
									class="rounded-[1.35rem] px-4 py-4 text-sm font-semibold"
									style="background: color-mix(in srgb, white 6%, transparent); border: 1px solid color-mix(in srgb, white 10%, transparent);"
								>
									{item}
								</div>
							))}
						</div>

						<div
							class="rounded-[1.6rem] px-5 py-5"
							style="background: color-mix(in srgb, white 6%, transparent); border: 1px solid color-mix(in srgb, white 10%, transparent);"
						>
							<p class="eyebrow-label" style="color: color-mix(in srgb, var(--color-background) 68%, transparent);">
								Response path
							</p>
							<div class="mt-4 grid gap-3 text-sm" style="color: color-mix(in srgb, var(--color-background) 80%, transparent);">
								<p><span class="mr-3 font-bold text-[var(--color-background)]">01</span>Get immediate movement alerts</p>
								<p><span class="mr-3 font-bold text-[var(--color-background)]">02</span>See live location and activity clearly</p>
								<p><span class="mr-3 font-bold text-[var(--color-background)]">03</span>Trigger support faster when needed</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}

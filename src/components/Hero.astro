---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";
import CallToActionButton from "./CallToActionButton.astro";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const content = data.content.heroSection;
const heroImage = data.imagery.heroImage;
const heroImageTextColor = data.imagery.heroTextColor;
const hasHeroImage = !!heroImage;
const heroHasLottie = data.imagery.heroHasLottie;
const heroLottie = data?.imagery?.lottiePath;
const showHeroLottie = Boolean(heroHasLottie && heroLottie);
const trust = data.content?.trustSection;
const services = data.content?.servicesSection?.listItems ?? [];
const highlights = [
	...(trust?.stats?.slice(0, 2).map((stat) => `${stat.value} ${stat.label}`) ?? []),
	...(trust?.guarantees?.slice(0, 1) ?? []),
].filter(Boolean);
// const locationLabel = [data.contact?.addressLocality, data.contact?.addressRegion]
// 	.filter(Boolean)
// 	.join(", ");

const textColor =
	hasHeroImage && heroImageTextColor
		? heroImageTextColor
		: `var(--color-heading)`;
---

{
	content && (
		<section
			class="hero scrolling-section relative isolate overflow-hidden px-6 pb-24 pt-14 sm:pt-20"
			style="background: var(--color-background); color: var(--color-text);"
			aria-label="Hero Section"
		>
			<div class="absolute inset-0 -z-10" aria-hidden="true">
				<div class="absolute -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full opacity-40 blur-3xl"
					style="background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 60%, transparent) 0%, transparent 70%);"
				></div>
				<div class="absolute -bottom-44 right-[-180px] h-[520px] w-[520px] rounded-full opacity-30 blur-3xl"
					style="background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 60%, transparent) 0%, transparent 70%);"
				></div>
				<div class="absolute inset-0 opacity-60"
					style="background: linear-gradient(180deg, color-mix(in srgb, var(--color-background) 92%, transparent) 0%, var(--color-background) 40%, var(--color-background) 100%);"
				></div>
			</div>

			<div class="mx-auto grid max-w-7xl items-start gap-14 lg:grid-cols-[1.05fr_0.95fr]">
				<div class="text-left">
					<p
						class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em]"
						style="background: color-mix(in srgb, var(--color-muted) 80%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent); color: var(--color-text);"
					>
						<span class="h-1.5 w-1.5 rounded-full" style="background: var(--color-accent);"></span>
						GPS Tracking • Fleet Security
					</p>

					<h1 class="mt-7 text-5xl font-black tracking-tight sm:text-6xl lg:text-7xl" style={`color: ${textColor}`}>
						{content.heading}
					</h1>

					<p class="mt-6 max-w-2xl text-lg leading-8 sm:text-xl" style="color: var(--color-text);">
						{content.paragraph}
					</p>

					<div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
						<CallToActionButton href={content.ctaUrl} label={content.ctaText} className="mt-0" />
						<a
							href="#services"
							data-button
							class="mt-8 inline-flex cursor-pointer items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold tracking-tight transition duration-300 hover:-translate-y-0.5"
							style="border: 1px solid color-mix(in srgb, var(--color-muted) 70%, transparent); background: color-mix(in srgb, var(--color-background) 70%, transparent); color: var(--color-heading);"
						>
							See what we install
							<Icon name="heroicons-solid:arrow-right" class="h-4 w-4" aria-hidden="true" />
						</a>
					</div>

					{highlights.length > 0 && (
						<div class="mt-10 flex flex-wrap gap-3">
							{highlights.map((item) => (
								<div
									class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm"
									style="background: color-mix(in srgb, var(--color-muted) 62%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 45%, transparent);"
								>
									<Icon name="heroicons-solid:badge-check" class="h-4 w-4" style="color: var(--color-accent);" aria-hidden="true" />
									<span class="font-medium" style="color: var(--color-heading);">{item}</span>
								</div>
							))}
						</div>
					)}

					{/* {locationLabel && (
						<p class="mt-6 text-sm" style="color: color-mix(in srgb, var(--color-text) 80%, transparent);">
							Installation support in {locationLabel} and nearby service areas.
						</p>
					)} */}
				</div>

				<div
					class="relative rounded-[32px] p-6"
					style="background: color-mix(in srgb, var(--color-muted) 70%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
				>
					<div
						class="absolute -top-8 -left-8 h-24 w-24 rounded-3xl opacity-35 blur-2xl"
						style="background: radial-gradient(circle, var(--color-primary) 0%, transparent 70%);"
						aria-hidden="true"
					></div>

					<div class="grid items-start gap-5 sm:grid-cols-2">
						<div
							class="rounded-[28px] p-6"
							style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
						>
							<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
								Live monitoring
							</p>
							<p class="mt-3 text-2xl font-bold leading-tight" style="color: var(--color-heading);">
								Know where it is. Know what it’s doing.
							</p>
							<p class="mt-3 text-sm leading-7" style="color: var(--color-text);">
								Track movement, alerts, and vehicle status with a setup designed for reliability.
							</p>
						</div>

						<div
							class="rounded-[28px] p-6"
							style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
						>
							<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
								Security response
							</p>
							<p class="mt-3 text-2xl font-bold leading-tight" style="color: var(--color-heading);">
								Act fast when something feels wrong.
							</p>
							<p class="mt-3 text-sm leading-7" style="color: var(--color-text);">
								Options include immobilizer, geofence alerts, and theft response support.
							</p>
						</div>
					</div>

					{showHeroLottie && (
						<div
							class="js-only mt-6 overflow-hidden rounded-[32px]"
							style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
						>
							<div class="h-[340px] w-full">
								<lottie-player
									src={heroLottie}
									background="transparent"
									speed="1"
									loop
									autoplay
									style="width: 100%; height: 100%"
								></lottie-player>
							</div>
						</div>
					)}

					{!showHeroLottie && hasHeroImage && (
						<div class="mt-6 overflow-hidden rounded-[32px]" style="border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);">
							<img
								src={heroImage}
								alt=""
								aria-hidden="true"
								class="h-[340px] w-full object-cover"
								fetchpriority="high"
								loading="eager"
								decoding="async"
							/>
						</div>
					)}

					{services.length > 0 && (
						<div class="mt-6 grid items-start gap-3 sm:grid-cols-2">
							{services.slice(0, 4).map((service) => (
								<div
									class="flex items-center gap-3 rounded-2xl px-4 py-4 text-sm self-start"
									style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
								>
									<Icon name="heroicons-solid:check-circle" class="h-5 w-5" style="color: var(--color-accent);" aria-hidden="true" />
									<span class="font-semibold" style="color: var(--color-heading);">{service.title}</span>
								</div>
							))}
						</div>
					)}
				</div>
			</div>
		</section>
	)
}

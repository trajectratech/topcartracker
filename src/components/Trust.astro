---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const trust = Astro.props.data?.content?.trustSection;
const stats = trust?.stats ?? [];
const guarantees = trust?.guarantees ?? [];
const ctaUrl = Astro.props.data?.content?.heroSection?.ctaUrl;

const getCountupTarget = (value: string) => {
	const trimmedValue = value.trim();
	if (!/^\d[\d,]*\+?$/.test(trimmedValue)) return null;

	const digits = trimmedValue.replace(/[^\d]/g, "");
	return digits ? Number.parseInt(digits, 10) : null;
};
---

{
	trust?.heading && (
		<section class="scrolling-section section-shell text-[var(--color-heading)]">
			<div class="container-shell">
				<div class="section-heading-center">
					<p class="section-kicker">Why Clients Trust Us</p>
					<h2 class="section-title" style="max-width: 13ch;">
						{trust.heading}
					</h2>
					<p class="section-copy">
						The difference is not just the tracker. It is the install quality, the support, and how fast the setup becomes useful when something goes wrong.
					</p>
				</div>

				<div class="mt-16 grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
					<div class="grid gap-5">
						{stats.map((stat) => {
							const numericValue = getCountupTarget(stat.value);
							return (
								<div class="metric-card">
									<p class="eyebrow-label">
										Proof
									</p>
									<p class="metric-value">
										{numericValue ? (
											<span
												data-countup
												data-target={String(numericValue)}
												data-final-value={stat.value}
											>
												{stat.value}
											</span>
										) : (
											stat.value
										)}
									</p>
									<p class="metric-label">
										{stat.label}
									</p>
								</div>
							);
						})}

						{ctaUrl && (
							<a
								href={ctaUrl}
								target="_blank"
								rel="noopener noreferrer"
								data-button
								class="cta-shell cursor-pointer self-start p-8 transition duration-300 hover:-translate-y-1"
							>
								<p class="eyebrow-label">
									Quick Quote
								</p>
								<p class="mt-4 text-2xl font-black tracking-[-0.04em] text-[var(--color-heading)]">
									Tell us the car type and the risk you want to reduce.
								</p>
								<p class="mt-4 text-sm leading-7 text-[var(--color-text-muted)]">
									Get a recommendation, installation direction, and the right protection level on WhatsApp.
								</p>
								<div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-heading)]">
									Get started
									<Icon name="heroicons-solid:external-link" class="h-4 w-4" aria-hidden="true" />
								</div>
							</a>
						)}
					</div>

					<div class="premium-panel self-start p-10">
						<div class="flex items-start justify-between gap-8">
							<div>
								<p class="eyebrow-label">
									What you can expect
								</p>
								<h3 class="mt-5 text-3xl font-black tracking-[-0.05em] text-[var(--color-heading)] sm:text-4xl">
									A cleaner experience from booking to after-sales support
								</h3>
								<p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-text-muted)]">
									You get clearer recommendations, better installation quality, and tracking tools that are chosen for real use, not feature overload.
								</p>
							</div>
							<div
								class="hidden sm:flex h-14 w-14 items-center justify-center rounded-3xl"
								style="background: color-mix(in srgb, var(--color-primary) 10%, transparent); border: 1px solid var(--border-subtle);"
								aria-hidden="true"
							>
								<Icon name="heroicons-solid:shield-check" class="h-6 w-6" style="color: var(--color-primary);" aria-hidden="true" />
							</div>
						</div>

						{guarantees.length > 0 && (
							<div class="mt-10 grid items-start gap-4 sm:grid-cols-2">
								{guarantees.map((guarantee) => (
									<div class="step-card self-start">
										<div class="flex items-start gap-3">
											<Icon name="heroicons-solid:badge-check" class="h-5 w-5" style="color: var(--color-primary);" aria-hidden="true" />
											<p class="text-base font-semibold text-[var(--color-heading)]">
												{guarantee}
											</p>
										</div>
										<p class="mt-3 text-sm leading-7 text-[var(--color-text-muted)]">
											Included as part of the full service, not added as an unclear extra later.
										</p>
									</div>
								))}
							</div>
						)}

						{Array.isArray(trust.trustBadges) && trust.trustBadges.length > 0 && (
							<div class="mt-12 flex flex-wrap items-center gap-6">
								{trust.trustBadges.map((badge, i) => (
									<img
										src={badge}
										alt={`Trust badge ${i + 1}`}
										class="h-10 sm:h-12 md:h-14 opacity-90 transition duration-300 hover:opacity-100"
									/>
								))}
							</div>
						)}
					</div>
				</div>
			</div>
			<script is:inline>
				const countupElements = document.querySelectorAll("[data-countup]");
				const formatCount = (value) => new Intl.NumberFormat("en-NG").format(value);

				const animateCount = (element) => {
					if (element.dataset.counted === "true") return;
					const target = Number.parseInt(element.dataset.target || "0", 10);
					const finalValue = element.dataset.finalValue || element.textContent || "";
					if (!target) return;

					element.dataset.counted = "true";
					const duration = 1400;
					const startValue = 1;
					const startTime = performance.now();

					const step = (now) => {
						const progress = Math.min((now - startTime) / duration, 1);
						const eased = 1 - Math.pow(1 - progress, 3);
						const currentValue = Math.round(
							startValue + (target - startValue) * eased,
						);

						element.textContent =
							progress < 1 ? formatCount(currentValue) : finalValue;

						if (progress < 1) {
							requestAnimationFrame(step);
						}
					};

					requestAnimationFrame(step);
				};

				if ("IntersectionObserver" in window) {
					const observer = new IntersectionObserver(
						(entries, currentObserver) => {
							entries.forEach((entry) => {
								if (!entry.isIntersecting) return;
								animateCount(entry.target);
								currentObserver.unobserve(entry.target);
							});
						},
						{ threshold: 0.4 },
					);

					countupElements.forEach((element) => observer.observe(element));
				} else {
					countupElements.forEach(animateCount);
				}
			</script>
		</section>
	)
}

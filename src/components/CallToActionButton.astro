---
// Props
export interface Props {
	href: string;
	label: string;
	target?: string;
	rel?: string;
	className?: string;
}
const href = Astro.props.href;
const label = Astro.props.label;
const isExternalLink =
	/^(https?:)?\/\//.test(href) ||
	href.startsWith("mailto:") ||
	href.startsWith("tel:");
const target = Astro.props.target ?? (isExternalLink ? "_blank" : "_self");
const rel = Astro.props.rel ?? (isExternalLink ? "noopener noreferrer" : undefined);
const className = Astro.props.className ?? "";
---

<a
	href={href}
	target={target}
	rel={rel}
	data-button
	style="background-color: var(--color-primary); color: var(--color-background) !important; -webkit-text-fill-color: var(--color-background); text-decoration: none;"
	class={`mt-8 inline-flex cursor-pointer items-center justify-center rounded-full px-6 py-3 text-sm font-semibold tracking-tight shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-primary)] ${className}`}
>
	{label}
</a>

---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const plans = Array.isArray(data?.pricing) ? data.pricing : [];
const primaryPlans = plans.slice(0, 3);
const packagePlans = plans.slice(3);
const recommendedIndex = primaryPlans.findIndex((plan) => /premium/i.test(plan.plan)) >= 0
	? primaryPlans.findIndex((plan) => /premium/i.test(plan.plan))
	: Math.min(1, Math.max(primaryPlans.length - 1, 0));
const ctaUrl = data?.content?.ctaSection?.ctaUrl || data?.content?.heroSection?.ctaUrl;
---

{
	Array.isArray(data?.pricing) && data.pricing.length > 0 && (
		<section
			id="pricing"
			aria-labelledby="pricing-heading"
			class="scrolling-section section-shell text-[var(--color-text)]"
			data-surface="muted"
		>
			<div class="container-shell">
				<div class="section-heading-center">
					<p class="section-kicker">Pricing</p>
					<h2 id="pricing-heading" class="section-title" style="max-width: 14ch;">
						Pick a plan that matches the level of protection you need.
					</h2>
					<p class="section-copy">
						Start with the right tracking foundation, then move up based on the features, control, and support your vehicle requires.
					</p>
					<p class="mx-auto mt-6 max-w-3xl text-sm font-semibold text-[var(--color-primary)]">
						Need help choosing? Tell us your car model and use case, and we will point you to the right setup.
					</p>
				</div>

				<div class="mt-16 grid items-start gap-6 lg:grid-cols-12" role="list">
					{primaryPlans.map((plan, idx) => (
						<article
							role="listitem"
							class={`lg:col-span-4 self-start p-8 transition duration-300 hover:-translate-y-1 ${
								idx === recommendedIndex ? "premium-panel" : "step-card"
							} flex h-full flex-col`}
							aria-label={`Pricing plan: ${plan.plan}`}
						>
							<header>
								<div class="flex items-center justify-between gap-4">
									<p class="eyebrow-label">
										{idx === recommendedIndex ? "Recommended" : `Plan ${idx + 1}`}
									</p>
									{idx === recommendedIndex && (
										<span class="rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em]" style="background: var(--color-primary); color: var(--color-background);">
											Best value
										</span>
									)}
								</div>
								<h3 class="mt-5 text-2xl font-black tracking-[-0.04em] text-[var(--color-heading)]">
									{plan.plan}
								</h3>
								<p class="mt-4 text-sm leading-7 text-[var(--color-text-muted)]">
									{idx === 0 && "A clean entry point for private vehicle owners who want reliable monitoring and essential protection."}
									{idx === 1 && "Balanced visibility and stronger everyday control for car owners who want more than the basics."}
									{idx === 2 && "For higher-risk use cases that need deeper alerts, stronger tamper resistance, and more active support."}
								</p>

								{plan.showPricing && plan.price ? (
									<p class="mt-4 text-3xl font-semibold" style="color: var(--color-accent);">
										{plan.price}
									</p>
								) : (
									<p class="mt-5 text-base font-semibold text-[var(--color-primary)]">
										Quote on request
									</p>
								)}
							</header>

							<ul class="mt-8 space-y-4 text-sm">
								{plan.features.slice(0, 7).map((feature) => (
									<li class="list-check">
										<span>{feature}</span>
									</li>
								))}
							</ul>

							{plan.features.length > 7 && (
								<p class="mt-5 text-sm font-semibold" style="color: var(--color-primary);">
									+{plan.features.length - 7} more included features
								</p>
							)}

							<div class="mt-6 rounded-[1.35rem] border px-4 py-4 text-sm" style="border-color: var(--border-subtle); background: color-mix(in srgb, var(--surface-accent) 72%, transparent);">
								<p class="eyebrow-label">Best for</p>
								<p class="mt-2 font-semibold text-[var(--color-heading)]">
									{idx === 0 && "Drivers who want a clean, affordable tracking entry point."}
									{idx === 1 && "Owners who want stronger everyday visibility and better app control."}
									{idx === 2 && "Higher-risk cars that need deeper alerts and more security layers."}
								</p>
							</div>

							{ctaUrl && (
								<a
									href={ctaUrl}
									target="_blank"
									rel="noopener noreferrer"
									data-button
									class={`mt-10 inline-flex cursor-pointer items-center justify-center gap-2 ${
										idx === recommendedIndex ? "primary-button" : "secondary-button"
									} mt-auto`}
								>
									Get this plan
									<Icon name="heroicons-solid:external-link" class="h-4 w-4" aria-hidden="true" />
								</a>
							)}
						</article>
					))}
			</div>

				{packagePlans.length > 0 && (
					<div class="mt-8 grid items-start gap-6">
						{packagePlans.map((plan) => (
							<article class="dark-panel self-start p-10">
								<div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
									<div>
										<p class="eyebrow-label" style="color: color-mix(in srgb, var(--color-background) 66%, transparent);">
											Bundle
										</p>
										<h3 class="mt-5 text-3xl font-black tracking-[-0.05em] sm:text-4xl">
											{plan.plan}
										</h3>
										<p class="mt-5 text-base leading-8" style="color: color-mix(in srgb, var(--color-background) 78%, transparent);">
											Combine multiple upgrades into one premium installation for stronger all-round protection.
										</p>
										<div class="mt-6 rounded-[1.4rem] border px-5 py-5 text-sm" style="border-color: color-mix(in srgb, white 10%, transparent); background: color-mix(in srgb, white 6%, transparent); color: color-mix(in srgb, var(--color-background) 80%, transparent);">
											<p class="eyebrow-label" style="color: color-mix(in srgb, var(--color-background) 66%, transparent);">
												Why choose this
											</p>
											<p class="mt-3 leading-7">
												Best for car owners who want tracking, incident recording, and stronger break-in resistance in one coordinated installation.
											</p>
										</div>
										{ctaUrl && (
											<a
												href={ctaUrl}
												target="_blank"
												rel="noopener noreferrer"
												data-button
												class="primary-button mt-8 inline-flex cursor-pointer items-center justify-center gap-2"
											>
												Get this package
												<Icon name="heroicons-solid:external-link" class="h-4 w-4" aria-hidden="true" />
											</a>
										)}
									</div>
									<div class="grid gap-4 sm:grid-cols-3">
										{plan.features.map((feature) => (
											<div
												class="rounded-[1.5rem] p-6 text-center"
												style="background: color-mix(in srgb, white 8%, transparent); border: 1px solid color-mix(in srgb, white 10%, transparent);"
											>
												<p class="font-semibold">{feature}</p>
											</div>
										))}
									</div>
								</div>
							</article>
						))}
					</div>
				)}
			</div>
		</section>
	)
}

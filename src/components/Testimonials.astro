---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const testimonialsSection = data.content?.testimonialsSection;
const testimonials = testimonialsSection?.testimonials ?? [];
const featured = testimonials[0];
const rest = testimonials.slice(1);

const totalRating = testimonials.reduce((sum, testimonial) => sum + testimonial.rating, 0);
const averageRating = testimonials.length
	? (totalRating / testimonials.length).toFixed(1)
	: null;

function getInitials(name: string) {
	return name
		.split(" ")
		.filter(Boolean)
		.slice(0, 2)
		.map((part) => part[0]?.toUpperCase() ?? "")
		.join("");
}
---

{Array.isArray(testimonialsSection?.testimonials) && testimonialsSection?.testimonials?.length > 0 && <section
	id="testimonials"
	aria-labelledby="testimonials-heading"
	class="scrolling-section section-shell"
>
	<div class="container-shell">
		<div class="section-heading-center">
			<p class="section-kicker">Customer Stories</p>
			{testimonialsSection?.heading && (
				<h2 id="testimonials-heading" class="section-title" style="max-width: 12ch;">
					{testimonialsSection.heading}
				</h2>
			)}
			<p class="section-copy">
				Real feedback from car owners, fleet operators, and security-focused clients.
			</p>
		</div>

		<div class="mt-12 flex flex-wrap justify-center gap-4">
			{averageRating && (
				<div class="chip px-5 py-3 text-sm">
					<Icon name="heroicons-solid:star" class="h-5 w-5" style="color: var(--color-accent);" aria-hidden="true" />
					<span class="font-semibold">
						{averageRating}/5 average rating
					</span>
				</div>
			)}
			<div class="chip px-5 py-3 text-sm">
				<Icon name="heroicons-solid:user-group" class="h-5 w-5" style="color: var(--color-primary);" aria-hidden="true" />
				<span class="font-semibold">
					{testimonials.length}+ reviews
				</span>
			</div>
		</div>

		<div class="mt-16 grid items-start gap-6 lg:grid-cols-[1.18fr_0.82fr]">
			{featured && (
				<figure class="premium-panel self-start p-10">
					<div class="flex items-center gap-1">
						{[...Array(featured.rating)].map(() => (
							<Icon name="heroicons-solid:star" class="h-5 w-5" style="color: var(--color-accent);" aria-hidden="true" />
						))}
					</div>
					<blockquote class="mt-8 max-w-4xl text-2xl font-semibold leading-10 text-[var(--color-heading)] sm:text-3xl">
						<p>“{featured.comment}”</p>
					</blockquote>
					<figcaption class="mt-10 flex items-center gap-4">
						{featured.avatarUrl ? (
							<img
								src={featured.avatarUrl}
								alt={`Avatar of ${featured.name}`}
								class="h-14 w-14 rounded-full object-cover"
								loading="lazy"
								decoding="async"
							/>
						) : (
							<div
								class="flex h-14 w-14 items-center justify-center rounded-full text-sm font-bold"
								style="background: color-mix(in srgb, var(--surface-base) 96%, transparent); border: 1px solid var(--border-subtle); color: var(--color-heading);"
							>
								{getInitials(featured.name)}
							</div>
						)}
						<div>
							<p class="text-sm font-semibold text-[var(--color-heading)]">{featured.name}</p>
							<p class="text-sm text-[var(--color-text-muted)]">{featured.position}</p>
						</div>
					</figcaption>
				</figure>
			)}

			<div class="premium-card p-8">
				<p class="eyebrow-label">Why this matters</p>
				<p class="mt-4 text-2xl font-black tracking-[-0.05em] text-[var(--color-heading)]">
					Clients stay because the setup keeps feeling useful after installation day.
				</p>
				<div class="mt-6 grid gap-4">
					<div class="step-card p-5">
						<p class="eyebrow-label">Trust signal</p>
						<p class="mt-3 text-lg font-bold tracking-[-0.03em] text-[var(--color-heading)]">
							Clear installation, better monitoring, real support.
						</p>
					</div>
					<div class="step-card p-5">
						<p class="eyebrow-label">What people mention</p>
						<p class="mt-3 text-sm leading-7 text-[var(--color-text-muted)]">
							Faster response, more confidence, and tracking tools that are easy to rely on daily.
						</p>
					</div>
				</div>
			</div>
		</div>

		{rest.length > 0 && (
			<div class="mt-6 grid items-start gap-6 md:grid-cols-2 xl:grid-cols-3">
				{rest.map((testimonial) => (
					<figure class="step-card self-start transition duration-300 hover:-translate-y-1">
						<div class="flex items-center gap-1">
							{[...Array(testimonial.rating)].map(() => (
								<Icon name="heroicons-solid:star" class="h-4 w-4" style="color: var(--color-accent);" aria-hidden="true" />
							))}
						</div>
						<blockquote class="mt-5 text-sm leading-7 text-[var(--color-text-muted)]">
							<p>“{testimonial.comment}”</p>
						</blockquote>
						<figcaption class="mt-6 border-t pt-5" style="border-color: var(--border-subtle);">
							<p class="text-sm font-semibold text-[var(--color-heading)]">{testimonial.name}</p>
							<p class="text-sm text-[var(--color-text-muted)]">{testimonial.position}</p>
						</figcaption>
					</figure>
				))}
			</div>
		)}
	</div>
</section>
}

---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const testimonialsSection = data.content?.testimonialsSection;
const testimonials = testimonialsSection?.testimonials ?? [];
const featured = testimonials[0];
const rest = testimonials.slice(1);

const totalRating = testimonials.reduce((sum, testimonial) => sum + testimonial.rating, 0);
const averageRating = testimonials.length
	? (totalRating / testimonials.length).toFixed(1)
	: null;

function getInitials(name: string) {
	return name
		.split(" ")
		.filter(Boolean)
		.slice(0, 2)
		.map((part) => part[0]?.toUpperCase() ?? "")
		.join("");
}
---

{Array.isArray(testimonialsSection?.testimonials) && testimonialsSection?.testimonials?.length > 0 && <section
	id="testimonials"
	aria-labelledby="testimonials-heading"
	class="scrolling-section bg-[var(--color-background)] px-6 py-28"
>
	<div class="mx-auto max-w-7xl">
		<div class="mx-auto max-w-3xl text-center">
			<p class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text);">
				Customer stories
			</p>
			{testimonialsSection?.heading && (
				<h2 id="testimonials-heading" class="mt-6 text-4xl font-black tracking-tight sm:text-5xl" style="color: var(--color-heading);">
					{testimonialsSection.heading}
				</h2>
			)}
			<p class="mt-6 text-lg leading-8" style="color: var(--color-text);">
				Real feedback from car owners, fleet operators, and security-focused clients.
			</p>
		</div>

		<div class="mt-12 flex flex-wrap justify-center gap-4">
			{averageRating && (
				<div
					class="inline-flex items-center gap-3 rounded-full px-5 py-3 text-sm"
					style="background: color-mix(in srgb, var(--color-muted) 62%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
				>
					<Icon name="heroicons-solid:star" class="h-5 w-5" style="color: var(--color-accent);" aria-hidden="true" />
					<span class="font-semibold" style="color: var(--color-heading);">
						{averageRating}/5 average rating
					</span>
				</div>
			)}
			<div
				class="inline-flex items-center gap-3 rounded-full px-5 py-3 text-sm"
				style="background: color-mix(in srgb, var(--color-muted) 62%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
			>
				<Icon name="heroicons-solid:user-group" class="h-5 w-5" style="color: var(--color-primary);" aria-hidden="true" />
				<span class="font-semibold" style="color: var(--color-heading);">
					{testimonials.length}+ reviews
				</span>
			</div>
		</div>

		<div class="mt-16 grid items-start gap-6 lg:grid-cols-12">
			{featured && (
				<figure
					class="card lg:col-span-7 self-start rounded-[34px] p-10"
					style="background: color-mix(in srgb, var(--color-muted) 74%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
				>
					<div class="flex items-center gap-1">
						{[...Array(featured.rating)].map(() => (
							<Icon name="heroicons-solid:star" class="h-5 w-5" style="color: var(--color-accent);" aria-hidden="true" />
						))}
					</div>
					<blockquote class="mt-8 text-2xl font-semibold leading-10 sm:text-3xl" style="color: var(--color-heading);">
						<p>“{featured.comment}”</p>
					</blockquote>
					<figcaption class="mt-10 flex items-center gap-4">
						{featured.avatarUrl ? (
							<img
								src={featured.avatarUrl}
								alt={`Avatar of ${featured.name}`}
								class="h-14 w-14 rounded-full object-cover"
								loading="lazy"
								decoding="async"
							/>
						) : (
							<div
								class="flex h-14 w-14 items-center justify-center rounded-full text-sm font-bold"
								style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent); color: var(--color-heading);"
							>
								{getInitials(featured.name)}
							</div>
						)}
						<div>
							<p class="text-sm font-semibold" style="color: var(--color-heading);">{featured.name}</p>
							<p class="text-sm" style="color: var(--color-text);">{featured.position}</p>
						</div>
					</figcaption>
				</figure>
			)}

			<div class="lg:col-span-5 grid items-start gap-6 sm:grid-cols-2 lg:grid-cols-1">
				{rest.slice(0, 4).map((testimonial) => (
					<figure
						class="card self-start rounded-[28px] p-7 transition duration-300 hover:-translate-y-1"
						style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
					>
						<div class="flex items-center gap-1">
							{[...Array(testimonial.rating)].map(() => (
								<Icon name="heroicons-solid:star" class="h-4 w-4" style="color: var(--color-accent);" aria-hidden="true" />
							))}
						</div>
						<blockquote class="mt-5 text-sm leading-7" style="color: var(--color-text);">
							<p>“{testimonial.comment}”</p>
						</blockquote>
						<figcaption class="mt-6 border-t pt-5" style="border-color: color-mix(in srgb, var(--color-muted) 55%, transparent);">
							<p class="text-sm font-semibold" style="color: var(--color-heading);">{testimonial.name}</p>
							<p class="text-sm" style="color: var(--color-text);">{testimonial.position}</p>
						</figcaption>
					</figure>
				))}
			</div>

			{rest.slice(4).length > 0 && (
				<div class="lg:col-span-12 grid items-start gap-6 md:grid-cols-3">
					{rest.slice(4).map((testimonial) => (
						<figure
							class="card self-start rounded-[28px] p-7 transition duration-300 hover:-translate-y-1"
							style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
						>
							<div class="flex items-center gap-1">
								{[...Array(testimonial.rating)].map(() => (
									<Icon name="heroicons-solid:star" class="h-4 w-4" style="color: var(--color-accent);" aria-hidden="true" />
								))}
							</div>
							<blockquote class="mt-5 text-sm leading-7" style="color: var(--color-text);">
								<p>“{testimonial.comment}”</p>
							</blockquote>
							<figcaption class="mt-6 border-t pt-5" style="border-color: color-mix(in srgb, var(--color-muted) 55%, transparent);">
								<p class="text-sm font-semibold" style="color: var(--color-heading);">{testimonial.name}</p>
								<p class="text-sm" style="color: var(--color-text);">{testimonial.position}</p>
							</figcaption>
						</figure>
					))}
				</div>
			)}
		</div>
	</div>
</section>
}

---
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { gallery, galleryTitle } = Astro.props.data.imagery;
---

{
	gallery && gallery.length > 0 && (
		<section
			id="gallery"
			aria-labelledby="gallery-heading"
			class="scrolling-section section-shell"
		>
			<div class="container-shell">
				{galleryTitle && (
					<div class="section-heading-center">
						<p class="section-kicker">Gallery</p>
						<h2 id="gallery-heading" class="section-title" style="max-width: 10ch;">
							{galleryTitle}
						</h2>
						<p class="section-copy">
							A quick look at installations, upgrades, and the kind of finish clients can expect.
						</p>
					</div>
				)}

				<div
					class="mt-16 grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
					role="list"
				>
					{gallery.map((img) => (
						<figure
							role="listitem"
							class="premium-card overflow-hidden transition duration-300 ease-in-out group hover:-translate-y-1"
						>
							<img
								src={img.imageUrl}
								alt={img?.alt || img?.caption || ""}
								class="w-full aspect-[4/3] object-cover"
								loading="lazy"
								decoding="async"
							/>
							{img.caption && (
								<figcaption class="px-4 py-4 text-sm font-semibold text-[var(--color-heading)]">
									{img.caption}
								</figcaption>
							)}
						</figure>
					))}
				</div>
			</div>
		</section>
	)
}

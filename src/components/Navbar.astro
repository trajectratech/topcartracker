---
import type { ThemeConfig } from "../types/theme";
import { getNavItemsFromTheme } from "../utils/getNavItems";
import CallToActionButton from "./CallToActionButton.astro";

export interface Props {
	data: ThemeConfig;
	mobileNavVariant?: "slide-down" | "slide-left" | "slide-right" | "fade";
}

const { data } = Astro.props;
const navItems = getNavItemsFromTheme(data);
---

<style>
	.mobile-panel {
		position: absolute;
		top: 64px;
		left: 12px;
		right: 12px;
		border-radius: 22px;
		background: var(--color-background);
		border: 1px solid color-mix(in srgb, var(--color-muted) 85%, transparent);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
		transform: translateY(-8px);
		opacity: 0;
		transition: transform 200ms ease, opacity 200ms ease;
	}

	details[open] .mobile-panel {
		transform: translateY(0);
		opacity: 1;
	}

	details > summary::-webkit-details-marker {
		display: none;
	}
</style>

<nav
	role="navigation"
	aria-label="Main navigation"
	class="w-full sticky top-0 z-50 text-[var(--color-text)] shadow-sm"
	style="background: var(--color-background); border-bottom: 1px solid color-mix(in srgb, var(--color-muted) 80%, transparent);"
>
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex items-center justify-between h-16">
			<!-- Logo -->
			<a href="/" class="cursor-pointer flex items-center space-x-2" aria-label={`${data.brand.businessName} home`}>
				{
					data.brand.logoImage && (
						<img
							src={data.brand.logoImage}
							alt={data.brand.businessName ? `${data.brand.businessName} logo` : "Site logo"}
							class="h-8 w-auto"
							width="32"
							height="32"
							loading="lazy"
							decoding="async"
							fetchpriority="high"
						/>
					)
				}
				{
					data.brand.businessName && (
						<span class="hidden md:inline text-lg font-bold text-[var(--color-primary)]">
							{data.brand.businessName}
						</span>
					)
				}
			</a>

			<!-- Desktop Nav -->
			<div class="hidden md:flex space-x-6">
				{
					navItems.map((item) =>
						item.external ? (
							<a
								href={item.href}
								target="_blank"
								rel="noopener noreferrer"
								data-button
								style="background-color: var(--color-primary); color: var(--color-background) !important; -webkit-text-fill-color: var(--color-background); text-decoration: none;"
								class="cursor-pointer inline-flex items-center justify-center text-sm font-semibold px-5 py-2.5 rounded-full shadow-sm transition duration-300 hover:-translate-y-0.5 hover:shadow-md"
							>
								{item.label}
							</a>
						) : (
							<a
								href={item.href}
								class="cursor-pointer text-sm font-medium !text-[var(--color-heading)] hover:!text-[var(--color-hover)] transition duration-300"
							>
								{item.label}
							</a>
						),
					)
				}
			</div>

			<!-- Mobile Toggle -->
			<details id="mobile-menu" class="md:hidden">
				<summary
					class="cursor-pointer rounded-full px-4 py-2 text-[var(--color-heading)] transition duration-200 hover:-translate-y-0.5"
					style="border: 1px solid color-mix(in srgb, var(--color-muted) 85%, transparent); background: var(--color-background);"
					aria-label="Menu"
				>
					<span aria-hidden="true">☰</span>
				</summary>

				<div class="mobile-panel">
					<div class="flex items-center justify-between px-5 pt-5">
						<p class="text-sm font-semibold" style="color: var(--color-heading);">
							Menu
						</p>
						<button
							data-mobile-close
							class="cursor-pointer rounded-full px-3 py-2 text-sm font-semibold transition duration-200 hover:-translate-y-0.5"
							style="border: 1px solid color-mix(in srgb, var(--color-muted) 85%, transparent); background: var(--color-background); color: var(--color-heading); text-decoration: none;"
							aria-label="Close menu"
							type="button"
						>
							<span aria-hidden="true">✕</span>
						</button>
					</div>

					<div class="mt-4 px-3 pb-5">
						<div
							class="rounded-2xl px-3 py-2"
							style="background: color-mix(in srgb, var(--color-muted) 55%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 85%, transparent);"
						>
							{navItems.map((item, index) =>
								item.external ? (
									<div class={index === 0 ? "" : "mt-3"}>
										<CallToActionButton href={item.href} label={item.label} className="mt-0 w-full" />
									</div>
								) : (
									<a
										href={item.href}
										data-mobile-link
										class="cursor-pointer flex items-center justify-between rounded-xl px-4 py-3 text-sm font-semibold transition duration-200 hover:-translate-y-0.5"
										style="color: var(--color-heading); text-decoration: none;"
									>
										<span>{item.label}</span>
										<span aria-hidden="true" style="color: var(--color-primary);">→</span>
									</a>
								),
							)}
						</div>
					</div>
				</div>

				<script type="module" is:inline>
					const root = document.getElementById("mobile-menu");
					if (root instanceof HTMLDetailsElement) {
						const close = () => root.removeAttribute("open");

						root.querySelectorAll("[data-mobile-link]").forEach((link) => {
							link.addEventListener("click", close);
						});

						const closeLink = root.querySelector("[data-mobile-close]");
						if (closeLink) {
							closeLink.addEventListener("click", (event) => {
								close();
							});
						}

						window.addEventListener("keydown", (event) => {
							if (event.key === "Escape") close();
						});

						const mediaQuery = window.matchMedia("(min-width: 768px)");
						mediaQuery.addEventListener("change", () => {
							if (mediaQuery.matches) close();
						});
					}
				</script>
			</details>
		</div>
	</div>
</nav>

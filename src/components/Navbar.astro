---
import type { ThemeConfig } from "../types/theme";
import { getNavItemsFromTheme } from "../utils/getNavItems";
import CallToActionButton from "./CallToActionButton.astro";

export interface Props {
	data: ThemeConfig;
	mobileNavVariant?: "slide-down" | "slide-left" | "slide-right" | "fade";
}

const { data } = Astro.props;
const navItems = getNavItemsFromTheme(data);
---

<style>
	.mobile-panel {
		position: absolute;
		top: calc(100% + 0.85rem);
		left: 0;
		right: 0;
		border-radius: 1.6rem;
		background: color-mix(in srgb, var(--surface-raised) 98%, transparent);
		border: 1px solid var(--border-subtle);
		box-shadow: var(--shadow-soft);
		transform: translateY(-8px);
		opacity: 0;
		transition: transform 200ms ease, opacity 200ms ease;
	}

	details[open] .mobile-panel {
		transform: translateY(0);
		opacity: 1;
	}

	details > summary::-webkit-details-marker {
		display: none;
	}
</style>

<nav
	role="navigation"
	aria-label="Main navigation"
	class="sticky top-0 z-50 px-4 pt-4 text-[var(--color-text)] sm:px-6"
>
	<div class="container-shell">
		<div class="premium-card flex min-h-18 items-center justify-between gap-4 px-4 py-3 sm:px-5">
			<a href="/" class="flex cursor-pointer items-center gap-3" aria-label={`${data.brand.businessName} home`}>
				{
					data.brand.logoImage && (
						<img
							src={data.brand.logoImage}
							alt={data.brand.businessName ? `${data.brand.businessName} logo` : "Site logo"}
							class="h-10 w-auto"
							width="40"
							height="40"
							loading="eager"
							decoding="async"
							fetchpriority="high"
						/>
					)
				}
				<div class="min-w-0">
					<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-text-muted)]">
						Vehicle Security
					</p>
					{
						data.brand.businessName && (
							<span class="block truncate text-base font-black tracking-[-0.03em] text-[var(--color-heading)] sm:text-lg">
								{data.brand.businessName}
							</span>
						)
					}
				</div>
			</a>

			<div class="hidden items-center gap-1 md:flex">
				{
					navItems.map((item) =>
						item.external ? (
							<a
								href={item.href}
								target="_blank"
								rel="noopener noreferrer"
								data-button
								class="primary-button cursor-pointer px-5 py-3 text-sm"
							>
								{item.label}
							</a>
						) : (
							<a
								href={item.href}
								class="cursor-pointer rounded-full px-4 py-3 text-sm font-semibold transition duration-200"
								style="color: var(--color-heading); text-decoration: none;"
							>
								{item.label}
							</a>
						),
					)
				}
			</div>

			<details id="mobile-menu" class="relative md:hidden">
				<summary
					class="secondary-button cursor-pointer px-4 py-3 text-sm"
					aria-label="Menu"
				>
					<span aria-hidden="true">Menu</span>
				</summary>

				<div class="mobile-panel">
					<div class="flex items-center justify-between px-5 pt-5">
						<p class="text-sm font-semibold tracking-[-0.02em]" style="color: var(--color-heading);">
							Menu
						</p>
						<button
							data-mobile-close
							class="secondary-button cursor-pointer px-3 py-2 text-sm"
							aria-label="Close menu"
							type="button"
						>
							<span aria-hidden="true">✕</span>
						</button>
					</div>

					<div class="mt-4 px-3 pb-5">
						<div class="grid gap-2 rounded-[1.4rem] bg-[color:color-mix(in_srgb,var(--surface-subtle)_78%,transparent)] px-3 py-3">
							{navItems.map((item, index) =>
								item.external ? (
									<div class={index === 0 ? "" : "mt-3"}>
										<CallToActionButton href={item.href} label={item.label} className="mt-0 w-full" />
									</div>
								) : (
									<a
										href={item.href}
										data-mobile-link
										class="cursor-pointer flex items-center justify-between rounded-[1rem] px-4 py-3 text-sm font-semibold transition duration-200"
										style="background: color-mix(in srgb, var(--surface-base) 98%, transparent); color: var(--color-heading); text-decoration: none;"
									>
										<span>{item.label}</span>
										<span aria-hidden="true" style="color: var(--color-primary);">→</span>
									</a>
								),
							)}
						</div>
					</div>
				</div>

				<script type="module" is:inline>
					const root = document.getElementById("mobile-menu");
					if (root instanceof HTMLDetailsElement) {
						const close = () => root.removeAttribute("open");

						root.querySelectorAll("[data-mobile-link]").forEach((link) => {
							link.addEventListener("click", close);
						});

						const closeLink = root.querySelector("[data-mobile-close]");
						if (closeLink) {
							closeLink.addEventListener("click", () => {
								close();
							});
						}

						window.addEventListener("keydown", (event) => {
							if (event.key === "Escape") close();
						});

						const mediaQuery = window.matchMedia("(min-width: 768px)");
						mediaQuery.addEventListener("change", () => {
							if (mediaQuery.matches) close();
						});
					}
				</script>
			</details>
		</div>
	</div>
</nav>

---
import type { ThemeConfig } from "../types/theme";
import dataJson from "../data/top-car-tracker.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLandingPageSeo } from "../utils/seo";
import { formatPhoneDisplay } from "../utils/formatPhone";

const data = dataJson as ThemeConfig;

export function getStaticPaths() {
	const theme = dataJson as ThemeConfig;
	const landingPages = theme.seo?.landingPages || [];

	return landingPages.map((page) => ({
		params: { slug: page.slug },
		props: { page },
	}));
}

const { page } = Astro.props;
const seo = getLandingPageSeo(data, page);
const displayPhone = formatPhoneDisplay(data.contact.phone);

const colorVars = {
	"--color-primary": data.colors.primary,
	"--color-secondary": data.colors.secondary,
	"--color-accent": data.colors.accent,
	"--color-background": data.colors.background,
	"--color-text": data.colors.text,
	"--color-heading": data.colors.heading,
	"--color-link": data.colors.link,
	"--color-hover": data.colors.hover,
	"--color-active": data.colors.active,
	"--color-error": data.colors.error,
	"--color-success": data.colors.success,
	"--color-muted": data.colors.muted,
};
---

<BaseLayout
	data={data}
	layout={[]}
	colorVars={colorVars}
	metadata={seo.metadata}
	structuredData={seo.structuredData}
	sameAsUrls={seo.sameAsUrls}
>
	<section class="bg-[var(--color-background)] px-6 py-16 md:py-24">
		<div class="mx-auto max-w-5xl">
			<div class="max-w-3xl">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-primary)]">
					{page.primaryKeyword}
				</p>
				<h1 class="mt-4 text-4xl font-extrabold tracking-tight text-[var(--color-heading)] md:text-5xl">
					{page.headline}
				</h1>
				<p class="mt-6 text-lg leading-8 text-[var(--color-text)]/80">
					{page.intro}
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a
						href={data.content.heroSection.ctaUrl}
						target="_blank"
						rel="noopener noreferrer"
						data-button
						style="background-color: var(--color-primary); color: var(--color-background) !important; -webkit-text-fill-color: var(--color-background); text-decoration: none;"
						class="cursor-pointer rounded-full px-6 py-3 font-semibold shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
					>
						{data.content.heroSection.ctaText}
					</a>
					<a
						href="/#services"
						data-button
						style="border-color: var(--color-primary); color: var(--color-primary) !important; -webkit-text-fill-color: var(--color-primary); text-decoration: none;"
						class="cursor-pointer rounded-full border px-6 py-3 font-semibold shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
					>
						View Services
					</a>
				</div>
			</div>

			<section class="mt-14" aria-labelledby="benefits-heading">
				<h2 id="benefits-heading" class="text-2xl font-bold text-[var(--color-heading)]">
					Key benefits
				</h2>
				<ul class="mt-6 grid gap-6 md:grid-cols-3" role="list">
					{page.benefits.map((benefit) => (
						<li>
							<article
								class="rounded-3xl p-6 shadow-sm"
								style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
							>
								<h3 class="text-lg font-bold text-[var(--color-heading)]">{benefit}</h3>
								<p class="mt-3 text-sm leading-7" style="color: var(--color-text);">
									{data.brand.businessName} helps clients in {page.location} with installation, monitoring, and after-sales support tailored to {page.serviceType.toLowerCase()}.
								</p>
							</article>
						</li>
					))}
				</ul>
			</section>

			<div class="mt-16 grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
				<article
					class="rounded-3xl p-8 shadow-sm"
					style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
				>
					<h2 class="text-2xl font-bold text-[var(--color-heading)]">
						Why this page matters
					</h2>
					<p class="mt-4 leading-8" style="color: var(--color-text);">
						This page focuses on {page.primaryKeyword} so search engines and AI systems can understand the exact service intent, business coverage, and local relevance of {data.brand.businessName}.
					</p>
					<p class="mt-4 leading-8" style="color: var(--color-text);">
						Primary service area: {page.location}. Core business category: {page.serviceType}. Supporting terms: {(page.secondaryKeywords || []).join(", ")}.
					</p>
				</article>

				<aside class="rounded-3xl p-8 shadow-sm" style="background: var(--color-heading); color: var(--color-background);">
					<h2 class="text-2xl font-bold">Contact {data.brand.businessName}</h2>
					<ul class="mt-5 space-y-3 text-sm leading-7" style="color: color-mix(in srgb, var(--color-background) 78%, transparent);">
						<li>{displayPhone}</li>
						<li>{data.contact.email}</li>
						<li>{data.contact.address}</li>
						<li>Coverage: {(data.seo?.serviceAreas || ["Nigeria"]).join(", ")}</li>
					</ul>
				</aside>
			</div>

			{page.faqs?.length ? (
				<section
					class="mt-16 rounded-3xl p-8 shadow-sm"
					style="background: color-mix(in srgb, var(--color-background) 76%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);"
				>
					<h2 class="text-2xl font-bold text-[var(--color-heading)]">
						{page.serviceType} FAQs
					</h2>
					<div class="mt-6 space-y-6">
						{page.faqs.map((faq) => (
							<article>
								<h3 class="text-lg font-semibold text-[var(--color-heading)]">
									{faq.question}
								</h3>
								<p class="mt-2 leading-8" style="color: var(--color-text);">
									{faq.answer}
								</p>
							</article>
						))}
					</div>
				</section>
			) : null}
		</div>
	</section>
</BaseLayout>

---
import type { ThemeConfig } from "../types/theme";
import dataJson from "../data/top-car-tracker.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLandingPageSeo } from "../utils/seo";

const data = dataJson as ThemeConfig;

export function getStaticPaths() {
	const theme = dataJson as ThemeConfig;
	const landingPages = theme.seo?.landingPages || [];

	return landingPages.map((page) => ({
		params: { slug: page.slug },
		props: { page },
	}));
}

const { page } = Astro.props;
const seo = getLandingPageSeo(data, page);

const colorVars = {
	"--color-primary": data.colors.primary,
	"--color-secondary": data.colors.secondary,
	"--color-accent": data.colors.accent,
	"--color-background": data.colors.background,
	"--color-text": data.colors.text,
	"--color-heading": data.colors.heading,
	"--color-link": data.colors.link,
	"--color-hover": data.colors.hover,
	"--color-active": data.colors.active,
	"--color-error": data.colors.error,
	"--color-success": data.colors.success,
	"--color-muted": data.colors.muted,
};
---

<BaseLayout
	data={data}
	layout={[]}
	colorVars={colorVars}
	metadata={seo.metadata}
	structuredData={seo.structuredData}
	sameAsUrls={seo.sameAsUrls}
>
	<section class="bg-[var(--color-background)] px-6 py-16 md:py-24">
		<div class="mx-auto max-w-5xl">
			<div class="max-w-3xl">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-primary)]">
					{page.primaryKeyword}
				</p>
				<h1 class="mt-4 text-4xl font-extrabold tracking-tight text-[var(--color-heading)] md:text-5xl">
					{page.headline}
				</h1>
				<p class="mt-6 text-lg leading-8 text-[var(--color-text)]/80">
					{page.intro}
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a
						href={data.content.heroSection.ctaUrl}
						class="cursor-pointer rounded-full bg-[var(--color-primary)] px-6 py-3 font-semibold text-white transition-transform duration-200 hover:scale-105"
					>
						{data.content.heroSection.ctaText}
					</a>
					<a
						href="/#services"
						class="cursor-pointer rounded-full border border-[var(--color-primary)] px-6 py-3 font-semibold text-[var(--color-primary)] transition-colors duration-200 hover:bg-[var(--color-primary)] hover:text-white"
					>
						View Services
					</a>
				</div>
			</div>

			<div class="mt-14 grid gap-6 md:grid-cols-3">
				{page.benefits.map((benefit) => (
					<article class="rounded-3xl border border-black/5 bg-white p-6 shadow-sm">
						<h2 class="text-lg font-bold text-[var(--color-heading)]">{benefit}</h2>
						<p class="mt-3 text-sm leading-7 text-[var(--color-text)]/75">
							{data.brand.businessName} helps clients in {page.location} with installation, monitoring, and after-sales support tailored to {page.serviceType.toLowerCase()}.
						</p>
					</article>
				))}
			</div>

			<div class="mt-16 grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
				<article class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-black/5">
					<h2 class="text-2xl font-bold text-[var(--color-heading)]">
						Why this page matters
					</h2>
					<p class="mt-4 leading-8 text-[var(--color-text)]/80">
						This page focuses on {page.primaryKeyword} so search engines and AI systems can understand the exact service intent, business coverage, and local relevance of {data.brand.businessName}.
					</p>
					<p class="mt-4 leading-8 text-[var(--color-text)]/80">
						Primary service area: {page.location}. Core business category: {page.serviceType}. Supporting terms: {(page.secondaryKeywords || []).join(", ")}.
					</p>
				</article>

				<aside class="rounded-3xl bg-[var(--color-heading)] p-8 text-white shadow-sm">
					<h2 class="text-2xl font-bold">Contact {data.brand.businessName}</h2>
					<ul class="mt-5 space-y-3 text-sm leading-7 text-white/80">
						<li>{data.contact.phone}</li>
						<li>{data.contact.email}</li>
						<li>{data.contact.address}</li>
						<li>Coverage: {(data.seo?.serviceAreas || ["Nigeria"]).join(", ")}</li>
					</ul>
				</aside>
			</div>

			{page.faqs?.length ? (
				<section class="mt-16 rounded-3xl bg-white p-8 shadow-sm ring-1 ring-black/5">
					<h2 class="text-2xl font-bold text-[var(--color-heading)]">
						{page.serviceType} FAQs
					</h2>
					<div class="mt-6 space-y-6">
						{page.faqs.map((faq) => (
							<article>
								<h3 class="text-lg font-semibold text-[var(--color-heading)]">
									{faq.question}
								</h3>
								<p class="mt-2 leading-8 text-[var(--color-text)]/80">
									{faq.answer}
								</p>
							</article>
						))}
					</div>
				</section>
			) : null}
		</div>
	</section>
</BaseLayout>
